---
import Layout from '../layouts/Layout.astro';

const projects = [
  { name: 'Luxe Skincare Co.', desc: 'Custom Shopify Plus store with subscription integration', tags: ['Shopify Plus', 'Custom Theme'] },
  { name: 'Urban Fit Athletics', desc: 'Headless commerce build with Hydrogen & Oxygen', tags: ['Hydrogen', 'Headless'] },
  { name: 'Brew & Bean Coffee', desc: 'Complete brand redesign and store migration', tags: ['Migration', 'Redesign'] },
  { name: 'Petals & Stems Florals', desc: 'Subscription-first flower delivery Shopify store', tags: ['Subscriptions', 'Custom App'] },
  { name: 'TechGear Electronics', desc: 'High-volume electronics store with custom filtering', tags: ['Shopify Plus', 'Performance'] },
  { name: 'Artisan Home Goods', desc: 'Multi-currency international expansion on Shopify Markets', tags: ['Markets', 'Multi-currency'] },
];

const testimonials = [
  { quote: 'Mubashir Design transformed our online presence. Our conversion rate increased by 40% within the first month of launch.', name: 'Sarah Chen', company: 'Luxe Skincare Co.' },
  { quote: 'Their deep Shopify expertise and attention to detail made them the perfect partner for our headless commerce migration.', name: 'Marcus Rodriguez', company: 'Urban Fit Athletics' },
  { quote: 'Professional, responsive, and incredibly talented. They delivered beyond our expectations on time and on budget.', name: 'Emma Walsh', company: 'Brew & Bean Coffee' },
];

const filters = ['All', 'Shopify Stores', 'Custom Apps', 'Redesigns', 'Headless Commerce'];
---

<Layout title="Our Work | Mubashir Design">
  <section class="page-header">
    <div class="container">
      <h1>Our Work</h1>
      <p>Shopify stores and ecommerce solutions we've crafted for our clients</p>
    </div>
  </section>

  <section class="filters">
    <div class="container">
      <div class="filter-bar">
        {filters.map((f, i) => (
          <button class:list={['filter-btn', { active: i === 0 }]}>{f}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="projects">
    <div class="container">
      <div class="projects-grid">
        {projects.map(p => (
          <div class="project-card card">
            <div class="project-image">
              <div class="project-placeholder"></div>
            </div>
            <div class="project-info">
              <h3>{p.name}</h3>
              <p>{p.desc}</p>
              <div class="project-tags">
                {p.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="project-link">View Project &rarr;</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="testimonials">
    <div class="container">
      <p class="section-label" style="text-align:center">Testimonials</p>
      <h2 class="section-title" style="text-align:center">What Our Clients Say</h2>
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="testimonial-card card">
            <p class="testimonial-quote">&ldquo;{t.quote}&rdquo;</p>
            <div class="testimonial-author">
              <div class="author-avatar"></div>
              <div>
                <span class="author-name">{t.name}</span>
                <span class="author-company">{t.company}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container" style="text-align:center">
      <h2>Have a project in mind?</h2>
      <p>We'd love to hear about it.</p>
      <a href="/contact" class="btn btn-primary">Let's Talk</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--gradient-purple);
    padding: 140px 0 80px;
  }
  .page-header h1 { font-size: 5.2rem; margin-bottom: 1.2rem; }
  .page-header p { font-size: 1.8rem; color: var(--light-gray); }

  .filters {
    background: var(--navy);
    padding: 2.4rem 0;
  }

  .filter-bar {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-primary);
    font-size: 1.3rem;
    font-weight: 400;
    padding: 0.8rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(106, 54, 217, 0.3);
    background: var(--dark-bg);
    color: var(--light-gray);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn.active,
  .filter-btn:hover {
    background: var(--cyan);
    color: var(--dark-bg);
    border-color: var(--cyan);
    font-weight: 400;
  }

  .projects {
    background: var(--dark-bg);
    padding: var(--section-padding);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.8rem;
  }

  .project-image { height: 220px; overflow: hidden; }
  .project-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #282c5a, #1c2049);
  }

  .project-info { padding: 2.4rem; }
  .project-info h3 { font-size: 2rem; font-weight: 400; margin-bottom: 0.6rem; }
  .project-info p { font-size: 1.4rem; margin-bottom: 1.4rem; }

  .project-tags {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 1.6rem;
  }

  .tag {
    font-size: 1.2rem;
    padding: 0.4rem 1.2rem;
    background: rgba(106, 54, 217, 0.25);
    color: var(--muted-purple);
    border-radius: var(--radius-xs);
  }

  .project-link { font-size: 1.4rem; color: var(--cyan); font-weight: 400; }

  /* Testimonials */
  .testimonials {
    background: var(--navy);
    padding: var(--section-padding);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.8rem;
    margin-top: 1rem;
  }

  .testimonial-card {
    padding: 3rem;
    background: var(--dark-bg);
  }

  .testimonial-quote {
    font-size: 1.5rem;
    font-style: italic;
    line-height: 1.7;
    margin-bottom: 2.4rem;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gradient-purple);
    flex-shrink: 0;
  }

  .author-name {
    display: block;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--white);
  }

  .author-company {
    display: block;
    font-size: 1.2rem;
    color: var(--muted-purple);
  }

  .cta {
    background: var(--gradient-purple);
    padding: var(--section-padding);
  }
  .cta h2 { margin-bottom: 1.2rem; }
  .cta p { font-size: 1.6rem; margin-bottom: 3rem; }

  @media (max-width: 989px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr; max-width: 600px; }
  }

  @media (max-width: 749px) {
    .page-header { padding: 110px 0 50px; }
    .page-header h1 { font-size: 3.6rem; }
    .projects, .testimonials, .cta { padding: var(--section-padding-mobile); }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
