---
import Layout from '../layouts/Layout.astro';

const faqs = [
  { q: 'What happens after I submit?', a: "We'll review your project details and schedule a free discovery call within 24 hours." },
  { q: "What's your typical timeline?", a: 'Most Shopify projects take 4-12 weeks depending on scope and complexity.' },
  { q: 'Do you offer ongoing support?', a: 'Yes! We offer flexible support plans for all our clients post-launch.' },
];
---

<Layout title="Contact | Mubashir Design">
  <section class="page-header">
    <div class="container">
      <h1>Get In Touch</h1>
      <p>Ready to take your ecommerce business to the next level? Let's talk.</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-card card">
          <form action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="company">Company / Brand</label>
              <input type="text" id="company" name="company" placeholder="Your company name" />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="project-type">Project Type</label>
                <select id="project-type" name="project_type">
                  <option value="">Select...</option>
                  <option>Shopify Store</option>
                  <option>App Development</option>
                  <option>Design</option>
                  <option>Consultation</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label for="budget">Budget Range</label>
                <select id="budget" name="budget">
                  <option value="">Select...</option>
                  <option>Under $5K</option>
                  <option>$5K - $15K</option>
                  <option>$15K - $50K</option>
                  <option>$50K+</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us about your project..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send Message</button>
          </form>
        </div>

        <div class="contact-sidebar">
          <div class="info-card card">
            <h3>Contact Information</h3>
            <div class="accent-line"></div>
            <div class="info-item">
              <span class="info-label">Email</span>
              <a href="mailto:hello@mubashirdesign.com">hello@mubashirdesign.com</a>
            </div>
            <div class="info-item">
              <span class="info-label">Location</span>
              <p>Toronto, Canada</p>
            </div>
            <div class="info-item">
              <span class="info-label">Response Time</span>
              <p>We typically respond within 24 hours</p>
            </div>
            <div class="info-item">
              <span class="info-label">Follow Us</span>
              <div class="contact-socials">
                <a href="https://github.com/mubashirdesign" target="_blank" rel="noopener" aria-label="GitHub">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="https://dribbble.com/mubashirdesign" target="_blank" rel="noopener" aria-label="Dribbble">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.628 0-12 5.373-12 12s5.372 12 12 12 12-5.373 12-12-5.372-12-12-12zm9.885 11.441c-2.575-.422-4.943-.445-7.103-.073-.244-.563-.497-1.125-.767-1.68 2.31-1 4.165-2.358 5.548-4.082 1.35 1.594 2.197 3.619 2.322 5.835zm-3.842-7.282c-1.205 1.554-2.868 2.783-4.986 3.68-1.016-1.861-2.178-3.676-3.488-5.438.779-.197 1.591-.314 2.431-.314 2.275 0 4.368.779 6.043 2.072zm-10.516-.993c1.331 1.742 2.511 3.538 3.537 5.381-2.43.715-5.331 1.082-8.684 1.105.692-2.835 2.601-5.193 5.147-6.486zm-5.44 8.834l.013-.256c3.849-.005 7.169-.448 9.95-1.322.233.475.456.952.67 1.432-3.38 1.057-6.165 3.222-8.337 6.48-1.432-1.719-2.296-3.927-2.296-6.334zm3.829 7.81c1.969-3.088 4.482-5.098 7.598-6.027.928 2.42 1.609 4.91 2.043 7.46-3.349 1.291-7.178.708-9.641-1.433zm11.586.43c-.438-2.353-1.08-4.653-1.92-6.897 1.876-.265 3.94-.196 6.199.196-.437 2.786-2.028 5.192-4.279 6.701z"/></svg>
                </a>
                <a href="https://linkedin.com/in/mubashirdesign" target="_blank" rel="noopener" aria-label="LinkedIn">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <div class="faq-card card">
            <h3>Frequently Asked</h3>
            {faqs.map(f => (
              <div class="faq-item">
                <h4>{f.q}</h4>
                <p>{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--gradient-purple);
    padding: 140px 0 80px;
  }
  .page-header h1 { font-size: 5.2rem; margin-bottom: 1.2rem; }
  .page-header p { font-size: 1.8rem; color: var(--light-gray); }

  .contact-section {
    background: var(--navy);
    padding: var(--section-padding);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form-card {
    padding: 4rem;
    background: var(--dark-bg);
  }

  .form-group {
    margin-bottom: 2.4rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  label {
    display: block;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--label-color);
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  input, select, textarea {
    width: 100%;
    padding: 1.2rem 1.6rem;
    font-family: var(--font-primary);
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--white);
    background: rgba(28, 32, 73, 0.6);
    border: 1px solid rgba(86, 0, 199, 0.3);
    border-radius: var(--radius-sm);
    box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--cyan);
  }

  input::placeholder, textarea::placeholder {
    color: #505480;
  }

  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%236971b9' stroke-width='1.5'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1.6rem center;
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-card, .faq-card {
    padding: 3rem;
    background: var(--dark-bg);
  }

  .info-card h3, .faq-card h3 {
    font-size: 2rem;
    margin-bottom: 1.2rem;
  }

  .accent-line {
    width: 50px;
    height: 3px;
    background: var(--cyan);
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  .info-item {
    margin-bottom: 2rem;
  }

  .info-label {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--label-color);
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.4rem;
  }

  .info-item a, .info-item p {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 0;
  }

  .contact-socials {
    display: flex;
    gap: 1rem;
    margin-top: 0.8rem;
  }

  .contact-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(106, 54, 217, 0.3);
    border: 1px solid rgba(159, 121, 255, 0.2);
    color: var(--light-gray);
    transition: all 0.3s ease;
  }

  .contact-socials a:hover {
    background: var(--cyan);
    color: var(--dark-bg);
    border-color: var(--cyan);
  }

  .faq-item {
    margin-bottom: 1.6rem;
  }

  .faq-item h4 {
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--cyan);
    margin-bottom: 0.4rem;
  }

  .faq-item p {
    font-size: 1.3rem;
    line-height: 1.6;
    margin-bottom: 0;
  }

  @media (max-width: 989px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-form-card { padding: 3rem; }
  }

  @media (max-width: 749px) {
    .page-header { padding: 110px 0 50px; }
    .page-header h1 { font-size: 3.6rem; }
    .contact-section { padding: var(--section-padding-mobile); }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
