---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mubashir Design — Your in-house Shopify team, on demand', description = 'Shopify-focused web development agency specializing in custom themes, app integrations, and growth-driven ecommerce solutions.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="grid-bg"></div>
    <slot />
  </body>
</html>
